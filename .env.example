# ─────────────────────────────────────────────────────────────
# Telegram Bot configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# On Netlify, add these as Site → Settings → Environment variables.
# ─────────────────────────────────────────────────────────────

# Your bot token from @BotFather
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Technician chat IDs — each person must message your bot first
# to generate their chat ID (use @userinfobot to find it).
TELEGRAM_JONATHAN_CHAT_ID=
TELEGRAM_PETER_CHAT_ID=
TELEGRAM_PORTIA_CHAT_ID=

# Customer chat IDs — in a real app these come from a database.
# For the demo, set them here and they'll be used by the closure notifier.
TELEGRAM_CUST_C0001_CHAT_ID=
TELEGRAM_CUST_C0002_CHAT_ID=
TELEGRAM_CUST_C0003_CHAT_ID=
TELEGRAM_CUST_C0004_CHAT_ID=
TELEGRAM_CUST_C0005_CHAT_ID=
